<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="创建链上卡牌游戏"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="最小玩家数："
            android:textSize="16sp"
            android:layout_gravity="center_vertical"/>
        <EditText
            android:id="@+id/et_min_players"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="2"
            android:inputType="number"
            android:paddingHorizontal="16dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="最大玩家数："
            android:textSize="16sp"
            android:layout_gravity="center_vertical"/>
        <EditText
            android:id="@+id/et_max_players"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="4"
            android:inputType="number"
            android:paddingHorizontal="16dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="最小质押（BKC）："
            android:textSize="16sp"
            android:layout_gravity="center_vertical"/>
        <EditText
            android:id="@+id/et_min_stake"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="10"
            android:inputType="number"
            android:paddingHorizontal="16dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="最大质押（BKC）："
            android:textSize="16sp"
            android:layout_gravity="center_vertical"/>
        <EditText
            android:id="@+id/et_max_stake"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="100"
            android:inputType="number"
            android:paddingHorizontal="16dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="小丑牌数量："
            android:textSize="16sp"
            android:layout_gravity="center_vertical"/>
        <EditText
            android:id="@+id/et_joker_count"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="1"
            android:inputType="number"
            android:paddingHorizontal="16dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="本人质押（BKC）："
            android:textSize="16sp"
            android:layout_gravity="center_vertical"/>
        <EditText
            android:id="@+id/et_my_stake"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="与最小～最大质押范围内"
            android:inputType="numberDecimal"
            android:paddingHorizontal="16dp"/>
    </LinearLayout>

    <Button
        android:id="@+id/btn_create_game"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="创建游戏"
        android:textSize="18sp"
        android:background="#2196F3"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_join_game"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="加入已有游戏"
        android:textSize="18sp"
        android:background="#2196F3"
        android:textColor="#FFFFFF"/>

</LinearLayout>