<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 黑色实心圆背景 -->
    <item android:width="39dp" android:height="39dp">
        <shape android:shape="oval">
            <solid android:color="#000000" />
        </shape>
    </item>

    <!-- 链上卡牌抽卡图标 -->
    <item
        android:width="20dp"
        android:height="20dp"
        android:gravity="center">
        <vector
            android:width="20dp"
            android:height="20dp"
            android:viewportWidth="20"
            android:viewportHeight="20">

            <!-- 卡牌边框 -->
            <path
                android:strokeColor="#FFFFFF"
                android:strokeWidth="1.2"
                android:pathData="M4,4 L16,4 A1,1 0 0 1 17,5 L17,15 A1,1 0 0 1 16,16 L4,16 A1,1 0 0 1 3,15 L3,5 A1,1 0 0 1 4,4 Z"/>

            <!-- 链条 -->
            <path
                android:strokeColor="#FFFFFF"
                android:strokeWidth="1.2"
                android:pathData="M6,6 L8,8 M8,6 L10,8 M10,6 L12,8"/>

            <!-- 抽卡箭头 -->
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M8,10 L12,12 L8,14 Z"/>
        </vector>
    </item>
</layer-list>