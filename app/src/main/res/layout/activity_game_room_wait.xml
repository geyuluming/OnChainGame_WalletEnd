<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="游戏房间等待中"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="30dp"/>

    <TextView
        android:id="@+id/tv_game_id"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="游戏ID：加载中..."
        android:textSize="16sp"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/tv_game_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="状态：加载中..."
        android:textSize="16sp"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/tv_player_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="玩家数：加载中..."
        android:textSize="16sp"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/tv_stake_amount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="质押金额：加载中..."
        android:textSize="16sp"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="玩家与质押（StakingVault）"
        android:textStyle="bold"
        android:layout_marginBottom="6dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tv_player_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="加载中..."
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:fontFamily="monospace"/>
    </ScrollView>

    <TextView
        android:id="@+id/tv_wait_tip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="请等待其他玩家加入..."
        android:textSize="14sp"
        android:textColor="#888888"
        android:gravity="center"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btn_start_game"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="开始游戏（房主）"
        android:textSize="18sp"
        android:background="#2196F3"
        android:textColor="#ffffff"/>

</LinearLayout>